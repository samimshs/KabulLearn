generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum UserRole {
  STUDENT
  EDUCATOR
  ADMIN
}

enum CourseStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
}

enum LessonType {
  VIDEO
  READING
  QUIZ
}

enum QuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  TEXT_INPUT
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum ReviewEventType {
  SUBMITTED
  PUBLISHED
  RETURNED
}

enum NotificationStatus {
  QUEUED
  SENT
  FAILED
}

enum AppNotificationKind {
  NEW_LESSON
  DISCUSSION_REPLY
  STREAK_ALERT
  COURSE_REVIEW
  GENERAL
}

enum EducatorRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum UserStatus {
  VERIFICATION_PENDING
  ACTIVE
  SUSPENDED
}

enum PaymentPurpose {
  COURSE
  DONATION
}

enum DiscountType {
  PERCENT
  FIXED_CENTS
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
  REFUNDED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  bio           String?   @db.Text
  passwordHash  String?
  role          UserRole  @default(STUDENT)
  status        UserStatus @default(ACTIVE)
  locale        String    @default("en")
  sessionVersion Int      @default(0)

  accounts        Account[]
  sessions        Session[]
  authoredCourses Course[]         @relation("CourseAuthor")
  reviewEvents    CourseReviewEvent[] @relation("ReviewActor")
  enrollments     Enrollment[]
  progressRecords UserProgress[]
  quizSubmissions QuizSubmission[]
  certificates    Certificate[]
  courseRatings   CourseRating[]
  lessonHeartbeats LessonHeartbeat[]
  quizAttemptSessions QuizAttemptSession[]
  discussionThreads DiscussionThread[]
  discussionReplies DiscussionReply[]
  lessonBookmarks LessonBookmark[]
  aiChatLogs      AiChatLog[]
  creatorProfile CreatorProfile? @relation("UserCreatorProfile")
  createdCreatorProfiles CreatorProfile[] @relation("CreatorProfileOwner")

  educatorRequest EducatorRequest?
  sentMessages     DirectMessage[] @relation("SentMessages")
  receivedMessages DirectMessage[] @relation("ReceivedMessages")
  streak           UserStreak?
  notifications    AppNotification[]
  lessonNotes      LessonNote[]
  adminAuditEvents AdminAuditLog[] @relation("AdminAuditActor")
  payments         Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminAuditLog {
  id        String   @id @default(cuid())
  actorId   String
  action    String
  targetId  String?
  targetType String?
  metadata  Json?
  createdAt DateTime @default(now())

  actor User @relation("AdminAuditActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([actorId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
}

model DirectMessage {
  id          String    @id @default(cuid())
  senderId    String
  recipientId String
  body        String    @db.Text
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  sender    User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  recipient User @relation("ReceivedMessages", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([recipientId])
  @@index([recipientId, readAt])
  @@index([senderId, recipientId, createdAt])
}

model EducatorRequest {
  id        String                @id @default(cuid())
  userId    String                @unique
  message   String                @db.Text
  status    EducatorRequestStatus @default(PENDING)
  adminNote String?               @db.Text
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
}

model CreatorProfile {
  id                String   @id @default(cuid())
  username          String   @unique
  name              String
  avatarUrl         String?
  professionalTitle   String?
  professionalTitlePs String?
  professionalTitleDa String?
  bio                 String?  @db.Text
  bioPs               String?  @db.Text
  bioDa               String?  @db.Text
  linkedinUrl       String?
  youtubeUrl        String?
  userId            String?  @unique
  createdById       String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User? @relation("UserCreatorProfile", fields: [userId], references: [id], onDelete: SetNull)
  createdBy User @relation("CreatorProfileOwner", fields: [createdById], references: [id], onDelete: Cascade)
  authoredCourses Course[] @relation("CoursePublicAuthor")
  courseInstructors CourseInstructor[]

  @@index([createdById])
}

model CourseInstructor {
  id        String         @id @default(cuid())
  courseId  String
  profileId String
  order     Int            @default(0)

  course  Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  profile CreatorProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([courseId, profileId])
  @@index([courseId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Course {
  id      String       @id @default(cuid())
  slug    String       @unique
  status  CourseStatus @default(DRAFT)
  level   String?

  titleEn       String
  titlePs       String
  titleDa       String?
  descriptionEn String @db.Text
  descriptionPs String @db.Text
  descriptionDa String? @db.Text

  authorId    String
  author      User          @relation("CourseAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  authorProfileId String?
  authorProfile   CreatorProfile? @relation("CoursePublicAuthor", fields: [authorProfileId], references: [id], onDelete: SetNull)
  instructors CourseInstructor[]
  modules     Module[]
  enrollments Enrollment[]
  certificates Certificate[]
  ratings      CourseRating[]
  payments     Payment[]
  reviewEvents CourseReviewEvent[]
  reviewChecklistItems CourseReviewChecklistItem[]
  discussionThreads DiscussionThread[]
  tags          CourseTagRelation[]
  announcements CourseAnnouncement[]
  learningPaths LearningPathCourse[]

  isPaid     Boolean @default(false)
  priceCents Int?
  currency   String  @default("usd")
  promoCodes PromoCode[]

  submittedAt DateTime?
  publishedAt DateTime?
  reviewNote  String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([authorId])
  @@index([authorProfileId])
  @@index([isPaid])
}

model Payment {
  id        String         @id @default(cuid())
  purpose   PaymentPurpose
  status    PaymentStatus  @default(PENDING)
  amountCents Int
  originalAmountCents Int?
  currency  String         @default("usd")

  userId   String?
  courseId String?
  promoCodeId String?

  stripeCheckoutSessionId String? @unique
  stripePaymentIntentId   String? @unique
  donorEmail String?
  donorName  String?
  metadata   Json?

  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  course    Course?    @relation(fields: [courseId], references: [id], onDelete: SetNull)
  promoCode PromoCode? @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([purpose])
  @@index([status])
  @@index([userId])
  @@index([courseId])
  @@index([promoCodeId])
  @@index([createdAt])
}

model PromoCode {
  id            String       @id @default(cuid())
  code          String       @unique
  discountType  DiscountType
  discountValue Int
  maxUses       Int?
  usedCount     Int          @default(0)
  expiresAt     DateTime?
  isActive      Boolean      @default(true)
  courseId      String?
  course        Course?      @relation(fields: [courseId], references: [id], onDelete: SetNull)
  payments      Payment[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([code])
  @@index([courseId])
  @@index([isActive])
}

model Module {
  id       String @id @default(cuid())
  courseId String
  order    Int

  titleEn       String
  titlePs       String
  titleDa       String?
  descriptionEn String? @db.Text
  descriptionPs String? @db.Text
  descriptionDa String? @db.Text

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([courseId, order])
  @@index([courseId])
}

model Lesson {
  id       String     @id @default(cuid())
  moduleId String
  order    Int
  type     LessonType

  titleEn       String
  titlePs       String
  titleDa       String?
  descriptionEn String? @db.Text
  descriptionPs String? @db.Text
  descriptionDa String? @db.Text

  youtubeUrl   String?
  readingEn    String? @db.Text
  readingPs    String? @db.Text
  readingDa    String? @db.Text
  isFinalTest  Boolean @default(false)
  passingScore Int?

  module      Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  quiz        Quiz?
  progress    UserProgress[]
  submissions QuizSubmission[]
  heartbeats   LessonHeartbeat[]
  quizAttemptSessions QuizAttemptSession[]
  notes       LessonNote[]
  bookmarks   LessonBookmark[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([moduleId, order])
  @@index([moduleId])
  @@index([type])
}

model Quiz {
  id       String @id @default(cuid())
  lessonId String @unique

  lesson    Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions Question[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Question {
  id     String       @id @default(cuid())
  quizId String
  order  Int
  type   QuestionType @default(SINGLE_CHOICE)

  promptEn      String  @db.Text
  promptPs      String  @db.Text
  promptDa      String? @db.Text
  correctAnswer String?
  explanationEn String? @db.Text
  explanationPs String? @db.Text
  explanationDa String? @db.Text

  quiz    Quiz                   @relation(fields: [quizId], references: [id], onDelete: Cascade)
  choices AnswerChoice[]
  answers QuizSubmissionAnswer[]

  @@unique([quizId, order])
  @@index([quizId])
}

model AnswerChoice {
  id         String @id @default(cuid())
  questionId String
  order      Int

  textEn    String
  textPs    String
  textDa    String?
  isCorrect Boolean @default(false)

  question   Question               @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selections QuizSubmissionAnswer[]

  @@unique([questionId, order])
  @@index([questionId])
}

model Enrollment {
  id       String @id @default(cuid())
  userId   String
  courseId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, courseId])
  @@index([courseId])
}

model UserProgress {
  id          String         @id @default(cuid())
  userId      String
  lessonId    String
  status      ProgressStatus @default(NOT_STARTED)
  completedAt DateTime?
  bestScore   Float?
  latestScore Float?
  attempts    Int            @default(0)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, lessonId])
  @@index([lessonId])
}

model QuizSubmission {
  id       String  @id @default(cuid())
  userId   String
  lessonId String
  score    Float
  passed   Boolean
  startedAt DateTime?
  durationMs Int?

  user    User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson  Lesson                 @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  answers QuizSubmissionAnswer[]

  submittedAt DateTime @default(now())

  @@index([userId, lessonId])
  @@index([lessonId])
  @@index([userId, lessonId, passed, submittedAt])
}

model QuizSubmissionAnswer {
  id             String @id @default(cuid())
  submissionId   String
  questionId     String
  answerChoiceId String?
  textAnswer     String?

  submission   QuizSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  question     Question       @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answerChoice AnswerChoice?  @relation(fields: [answerChoiceId], references: [id], onDelete: Restrict)

  @@unique([submissionId, questionId, answerChoiceId])
  @@index([questionId])
}

model Certificate {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  uuid             String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String
  courseId         String
  grade            Float
  verificationCode String   @unique @default(cuid())
  issuedAt         DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId])
}

model LessonHeartbeat {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  courseId    String
  positionSec Float
  durationSec Float
  consumedPct Float
  signature   String
  createdAt   DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([userId, lessonId, createdAt])
  @@index([courseId])
}

model QuizAttemptSession {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  courseId  String
  moduleId  String
  startedAt DateTime @default(now())
  expiresAt DateTime
  usedAt    DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([userId, lessonId, startedAt])
  @@index([courseId])
}


model CourseRating {
  id       String @id @default(cuid())
  userId   String
  courseId String
  rating   Int
  comment  String? @db.Text

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, courseId])
  @@index([courseId])
}

model CourseReviewEvent {
  id        String          @id @default(cuid())
  courseId  String
  actorId   String
  type      ReviewEventType
  note      String?         @db.Text
  createdAt DateTime        @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  actor  User   @relation("ReviewActor", fields: [actorId], references: [id], onDelete: Restrict)

  @@index([courseId])
  @@index([actorId])
}

model CourseReviewChecklistItem {
  id        String   @id @default(cuid())
  courseId  String
  label     String
  passed    Boolean  @default(false)
  note      String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

model DiscussionThread {
  id        String   @id @default(cuid())
  courseId  String
  authorId  String
  title     String
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  replies DiscussionReply[]

  @@index([courseId])
  @@index([authorId])
}

model DiscussionReply {
  id        String   @id @default(cuid())
  threadId  String
  authorId  String
  body      String   @db.Text
  createdAt DateTime @default(now())

  thread DiscussionThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author User             @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@index([authorId])
}

model NotificationLog {
  id        String             @id @default(cuid())
  email     String
  subject   String
  body      String             @db.Text
  status    NotificationStatus @default(QUEUED)
  createdAt DateTime           @default(now())
  sentAt     DateTime?

  @@index([email])
  @@index([status])
}

model SiteSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

model AppNotification {
  id        String              @id @default(cuid())
  userId    String
  kind      AppNotificationKind @default(GENERAL)
  title     String
  body      String              @db.Text
  link      String?
  readAt    DateTime?
  createdAt DateTime            @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, readAt])
}

model CourseTag {
  id    String @id @default(cuid())
  label String @unique
  slug  String @unique

  courses CourseTagRelation[]
}

model CourseTagRelation {
  courseId String
  tagId    String

  course Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  tag    CourseTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([courseId, tagId])
  @@index([tagId])
}

model LessonNote {
  id       String @id @default(cuid())
  userId   String
  lessonId String
  body     String @db.Text

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, lessonId])
  @@index([userId])
}

model LessonBookmark {
  id       String @id @default(cuid())
  userId   String
  lessonId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
}

model LearningPath {
  id          String @id @default(cuid())
  slug        String @unique
  titleEn     String
  titlePs     String
  titleDa     String?
  descriptionEn String @db.Text
  descriptionPs String @db.Text
  descriptionDa String? @db.Text
  coverColor  String  @default("#0057FF")
  order       Int     @default(0)

  courses LearningPathCourse[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LearningPathCourse {
  pathId   String
  courseId String
  order    Int

  path   LearningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)
  course Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@id([pathId, courseId])
  @@index([courseId])
}

model CourseAnnouncement {
  id       String  @id @default(cuid())
  courseId String
  title    String?
  body     String  @db.Text

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([courseId])
}

model UserStreak {
  userId        String   @id
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentStreak Int      @default(1)
  longestStreak Int      @default(1)
  lastActiveDate DateTime @db.Date
  updatedAt     DateTime @updatedAt
}

model ContentEmbedding {
  id        String   @id @default(cuid())
  source    String   // "lesson" | "course" | "terms" | "privacy" | "guide"
  sourceKey String   // stable unique key within source (DB id or slug)
  title     String
  chunkText String   @db.Text
  embedding Unsupported("vector(1536)")?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([source, sourceKey])
  @@index([source])
}

model AiChatLog {
  id        String   @id @default(cuid())
  userId    String
  courseId  String?
  question  String   @db.Text
  answer    String?  @db.Text
  sources   Json?
  rating    Int?
  feedback  String?  @db.Text
  locale    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([courseId])
  @@index([rating])
  @@index([createdAt])
}
